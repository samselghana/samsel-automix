APP_NAME=AutoMix Downloader Service
APP_HOST=0.0.0.0
APP_PORT=8010
DATABASE_URL=sqlite:///./jobs.db
DOWNLOAD_ROOT=./downloads
TEMP_ROOT=./temp
WORKER_POLL_SECONDS=1
MAX_WORKERS=2
MAX_ATTEMPTS=4
RETRY_BASE_SECONDS=30
RETRY_MAX_SECONDS=1800
DEFAULT_AUDIO_PROVIDER=youtube-music
DEFAULT_OUTPUT_TEMPLATE={artist} - {title}.{output-ext}
MIXER_IMPORT_ROOT=./mixer_import
SPOTIFY_COOKIE_FILE=
YOUTUBE_COOKIE_FILE=
MIXER_WEBHOOK_URL=
REQUEST_TIMEOUT_SECONDS=1800
USE_SPOTDL_CLI=true
